# Telegram bot token
TOKEN=PUT_YOUR_TOKEN_HERE
# Alternative env name for the bot token
TELEGRAM_BOT_TOKEN=PUT_YOUR_TOKEN_HERE

# Project and data directories
PROJECT_ROOT=./
DATA_DIR=./data

# Redis and database
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://maxbot:maxbot@localhost:5432/maxbot

# API settings
API_HOST=0.0.0.0
API_PORT=5000
CACHE_TTL_SECONDS=60

# Machine learning / model training
ML_BATCH_SIZE=64

# Redis streams used for inference
INFERENCE_STREAM=inference:messages
INFERENCE_CONSUMER_GROUP=ml-workers
INFERENCE_RESULT_STREAM=inference:results
INFERENCE_RESULT_CONSUMER_GROUP=bot-senders
